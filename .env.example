# Neo4j AuraDB (ou Neo4j local)
# Pour AuraDB Free : télécharger le fichier de connexion depuis la console au
# moment de la création de l'instance (le password n'est affiché qu'UNE FOIS).
# Format AuraDB URI : neo4j+s://<id>.databases.neo4j.io
# Format local URI  : bolt://localhost:7687
#
# Note AuraDB : NEO4J_USERNAME, NEO4J_DATABASE et AURA_INSTANCEID ont la même
# valeur (= l'identifiant unique de l'instance, ex. "xxxxxxxx" ci-dessous).
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=xxxxxxxx
NEO4J_PASSWORD=replace_me
NEO4J_DATABASE=xxxxxxxx
AURA_INSTANCEID=xxxxxxxx
AURA_INSTANCENAME=Free instance

# Anthropic API — clé depuis console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-replace_me
